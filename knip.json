{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/routes/**/*.{ts,tsx}",
    "app/router.tsx",
    "app/sitemap.tsx",
    "server.ts",
    "app/**/*.stories.tsx",
    ".storybook/{main,preview}.{ts,tsx}",
    "tests/**/*.spec.ts",
    "tests/setup/global-setup.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "server.ts",
    "scripts/*.mjs",
    "tests/**/*.ts"
  ],
  "ignore": ["app/routeTree.gen.ts"],
  "ignoreBinaries": ["scripts/deploy.sh"],
  "ignoreDependencies": ["tailwindcss"]
}
