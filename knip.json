{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/routes/**/*.{ts,tsx}",
    "app/router.tsx",
    "app/sitemap.tsx",
    "app/**/*.stories.tsx",
    ".storybook/{main,preview}.{ts,tsx}",
    "tests/**/*.spec.ts"
  ],
  "project": ["app/**/*.{ts,tsx}", "scripts/*.mjs", "tests/**/*.ts"],
  "ignore": ["app/routeTree.gen.ts"],
  "ignoreBinaries": ["scripts/deploy.sh"],
  "ignoreDependencies": ["tailwindcss"]
}
